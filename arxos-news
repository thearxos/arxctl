#!/usr/bin/env python3
# arxos-news 0.0.1 - desktop notifications for new ARXOS tool activity.
# Polls each ARXOS repo's latest commit via the GitHub API, compares to the
# last-seen SHA, and fires a right-side desktop notification for anything new
# (new tools, fixes, kernel improvements) sourced straight from commit messages.
# Idle-friendly: one tiny HTTP call per repo per run, no clones, long interval.
import json, os, subprocess, sys, urllib.request

VERSION = "0.0.1"
OWNER = "thearxos"
MANIFEST = os.environ.get("ARXOS_REPOS", "/etc/arxos/repos.list")
CACHE = os.path.join(os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "arxos")
STATE = os.path.join(CACHE, "news-seen.json")
COUNT = os.path.join(CACHE, "news-count")

def icon(m):
    m = m.lower()
    if "kernel" in m or "perf" in m or "idle" in m or "speed" in m: return "cpu"
    if "fix" in m or "bug" in m or "repair" in m or "patch" in m: return "dialog-warning"
    if any(k in m for k in ("add", "new", "feat", "ship", "weapon", "tool", "arsenal")): return "software-update-available"
    return "security-high"

def repos():
    try:
        for ln in open(MANIFEST):
            ln = ln.strip()
            if ln and not ln.startswith("#"):
                yield ln.split()[0]
    except Exception:
        return

def latest(name):
    req = urllib.request.Request(
        "https://api.github.com/repos/%s/%s/commits?per_page=1" % (OWNER, name),
        headers={"User-Agent": "ARXOS-news/%s" % VERSION, "Accept": "application/vnd.github+json"})
    d = json.load(urllib.request.urlopen(req, timeout=12))
    if not d: return None, None
    return d[0]["sha"], d[0]["commit"]["message"].splitlines()[0][:120]

def main():
    os.makedirs(CACHE, exist_ok=True)
    try: seen = json.load(open(STATE))
    except Exception: seen = {}
    first = not seen
    force = "--notify-all" in sys.argv      # for testing: notify even on first/forced run
    new = 0
    for name in repos():
        try: sha, msg = latest(name)
        except Exception: continue
        if not sha: continue
        try:
            if name not in seen:
                # a repo newly added to the registry = a new ARXOS tool shipped
                if not first or force:
                    subprocess.Popen(["notify-send", "-a", "ARXOS", "-u", "normal",
                                      "-i", "software-update-available", "ARXOS · new tool",
                                      "%s shipped to ARXOS" % name]); new += 1
            elif seen[name] != sha or force:
                subprocess.Popen(["notify-send", "-a", "ARXOS", "-u", "normal",
                                  "-i", icon(msg), "ARXOS · %s" % name, msg]); new += 1
        except Exception: pass
        seen[name] = sha
    json.dump(seen, open(STATE, "w"))
    open(COUNT, "w").write(str(new))
    if "--quiet" not in sys.argv:
        print("arxos-news: %d new (tracking %d repos)" % (new, len(seen)))

if __name__ == "__main__":
    if "--version" in sys.argv or "-V" in sys.argv:
        print("arxos-news %s (ARXOS)" % VERSION); sys.exit(0)
    main()
