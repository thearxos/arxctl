    def refresh(self):
        self.vals["kernel"].set_text(sh("uname -r") or "?")
        c = cpu_pct(); gov = sh("cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor")
        cv = self.vals["cpu"]; cv.set_text(("%d%%" % c if c is not None else "n/a") + ("  ·  " + gov if gov else ""))
        cv.get_style_context().remove_class("warn")
        if c is not None and c >= 80: cv.get_style_context().add_class("warn")
        self.vals["memory"].set_text(sh("free -m | awk '/Mem:/{printf \"%d / %d MB\", $3, $2}'") or "?")
        tv = self.vals["tor"]; tv.get_style_context().remove_class("on"); tv.get_style_context().remove_class("warn")
        istor, ip = net_info()
        proxy = sh("grep -q '^nameserver 127.0.0.1' /etc/resolv.conf 2>/dev/null && echo 1") == "1"
        if istor:
            tv.set_text("via Tor · %s" % (ip or "…")); tv.get_style_context().add_class("on")
        elif proxy:
            tv.set_text("starting · %s" % (ip or "…")); tv.get_style_context().add_class("warn")
        elif istor is None:
            tv.set_text("checking…")
        else:
            tv.set_text("off" + (" · %s" % ip if ip else ""))
        self.vals["updated"].set_text(last_mod())
        u = updates_count(); uv = self.vals["updates"]; uv.get_style_context().remove_class("warn"); uv.get_style_context().remove_class("on")
        if u is None: uv.set_text("checking…")
        elif u == 0: uv.set_text("up to date"); uv.get_style_context().add_class("on")
        else: uv.set_text("%d available" % u); uv.get_style_context().add_class("warn")
        return True

