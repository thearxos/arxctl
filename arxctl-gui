    def sysinfo(self, *_):
        d, a = self._dialog("System Information", 540, 580)
        sc = Gtk.ScrolledWindow(); sc.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        box.set_margin_start(4); box.set_margin_end(8); sc.add(box); a.pack_start(sc, True, True, 0)
        ld = Gtk.Label(label="gathering hardware + OS report…"); ld.set_xalign(0); ld.get_style_context().add_class("statlabel"); box.pack_start(ld, False, False, 0)
        report = {"txt": ""}
        def render(data):
            report["txt"] = data
            for c in box.get_children(): c.destroy()
            grid = None
            for line in data.splitlines():
                if line.startswith("@"):
                    h = Gtk.Label(); h.set_markup("<span foreground='#e8702a' weight='700' size='small'>%s</span>" % line[1:]); h.set_xalign(0); h.set_margin_top(13)
                    box.pack_start(h, False, False, 0)
                    grid = Gtk.Grid(column_spacing=14, row_spacing=4); grid.set_margin_top(3); box.pack_start(grid, False, False, 0); grid.r = 0
                elif "|" in line and grid is not None:
                    k, v = line.split("|", 1)
                    kl = Gtk.Label(label=k); kl.set_xalign(0); kl.set_valign(Gtk.Align.START); kl.set_size_request(92, -1); kl.get_style_context().add_class("statlabel")
                    vl = Gtk.Label(label=v.strip() or "—"); vl.set_xalign(0); vl.set_line_wrap(True); vl.set_selectable(True); vl.get_style_context().add_class("statvalue")
                    grid.attach(kl, 0, grid.r, 1, 1); grid.attach(vl, 1, grid.r, 1, 1); grid.r += 1
            box.show_all(); return False
        def gather():
            data = sh(r'''
echo "@OPERATING SYSTEM"
echo "OS|$(. /etc/os-release 2>/dev/null; echo ${PRETTY_NAME:-ARXOS}) · Arch-based"
echo "Kernel|$(uname -sr)"
echo "Uptime|$(uptime -p 2>/dev/null | sed 's/^up //')"
echo "Packages|$(pacman -Qq 2>/dev/null | wc -l) native$(command -v yay>/dev/null && echo " · $(yay -Qm 2>/dev/null|wc -l) AUR")"
