    def _dialog(self, title, w=420, h=380):
        # Non-modal: a panel that does NOT spin a blocking nested loop, so output
        # windows (leak test, tor actions) spawned from it stay interactive and
        # their Close button works immediately.
        d = Gtk.Dialog(title=title, transient_for=self, modal=False); d.set_default_size(w, h)
        d.add_button("Close", Gtk.ResponseType.CLOSE)
        a = d.get_content_area(); a.set_spacing(6)
        for m in ("set_margin_top","set_margin_bottom","set_margin_start","set_margin_end"): getattr(a, m)(14)
        return d, a

    def _show(self, d):
        # Replaces the old blocking `d.show_all(); d.run(); d.destroy()`.
        d.connect("response", lambda dd, *_: dd.destroy())
        d.show_all()

    def kernels(self, *_):
        d, a = self._dialog("Kernels", 470, 390)
        run = sh("uname -r")
        h = Gtk.Label(); h.set_markup("Running:  <span foreground='#5fd17a'><b>%s</b></span>" % run); h.set_xalign(0)
        a.pack_start(h, False, False, 4)
        inst = lambda kk: lambda *_: term("arx install %s %s-headers; echo; read -rp 'done — enter…'" % (kk, kk))
        rem  = lambda kk: lambda *_: term("arx remove %s %s-headers; echo; read -rp 'done — enter…'" % (kk, kk))
        for k in KERNELS:
            installed = sh("pacman -Qq %s 2>/dev/null" % k) == k
            ver = sh("pacman -Q %s 2>/dev/null" % k); ver = ver.split()[-1] if ver else ""
            tag = "" if k == "linux" else k.split("-", 1)[1]
            running = installed and ((tag and tag in run) or (k == "linux" and not any(x in run for x in ("zen","lts","hardened"))))
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            lbl = Gtk.Label(label=k); lbl.set_xalign(0); lbl.set_size_request(108,-1); lbl.get_style_context().add_class("krow")
            if running: lbl.get_style_context().add_class("krun")
            row.pack_start(lbl, False, False, 0)
            st = Gtk.Label(label=(ver + ("  · running" if running else "") if installed else "not installed")); st.set_xalign(0); st.get_style_context().add_class("statlabel")
            row.pack_start(st, True, True, 0)
            if not installed:
